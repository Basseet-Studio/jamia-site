rules_version = '2';

// Veeramangalam Juma Masjid Household Finance Dashboard
// Hierarchy: household -> family -> members. Members are per-family.
// See specs/001-household-finance-dashboard/contracts/firestore.rules for v1 origin.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validOptionalAttachment() {
      return !('attachmentPath' in request.resource.data)
        || request.resource.data.attachmentPath == null
        || (
          request.resource.data.attachmentPath is string
          && request.resource.data.attachmentPath.matches('^receipts/')
          && request.resource.data.attachmentFileName is string
          && request.resource.data.attachmentMimeType is string
        );
    }

    // ---- admins ----

    match /admins/{uid} {
      allow read: if isSignedIn();

      // Self-service admin management. Rules are intentionally permissive
      // on `create` — the service layer in `admins.ts` is the one that
      // enforces "only the first user can self-promote" (via a Firestore
      // transaction that reads the collection, checks size, and only then
      // writes). The shape is the only thing the rule checks.
      //
      // After the first admin exists, normal add/remove goes through the
      // admin-management UI in Settings.
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.keys().hasAll([
          'email', 'displayName', 'role'
        ])
        && request.resource.data.role in ['owner', 'admin']
        && request.resource.data.email is string
        && request.resource.data.displayName is string;

      // Only admins can mutate an existing admin doc. This is the gate the
      // service uses for self-update (display name only) and other updates.
      allow update: if isAdmin();

      // Only admins can remove admin docs. The service layer blocks
      // self-removal if it would leave the collection empty.
      allow delete: if isAdmin();
    }

    // ---- settings ----

    match /settings/{doc} {
      allow read: if isAdmin();
      allow write: if isAdmin()
        && doc == 'global'
        && request.resource.data.keys().hasAll(['defaultContributionTarget', 'openingBalance', 'currency']);
    }

    // ---- households ----

    match /households/{householdId} {
      allow read: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time;

      // The household doc carries identity only — no member fields. All other
      // edits (e.g. name) are still blocked.
      allow update: if false;

      allow delete: if isAdmin();

      // ---- families (sub-collection) ----

      match /families/{familyId} {
        allow read: if isAdmin();

        allow create: if isAdmin()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.createdAt == request.time
          && request.resource.data.active == true
          && request.resource.data.deletedAt == null
          && request.resource.data.deletedBy == null
          && request.resource.data.contributionTarget is number
          && request.resource.data.contributionTarget >= 0
          && request.resource.data.memberCount == 0
          && request.resource.data.memberNames.size() == 0;

        // Three allowed transitions, expressed as allowed affectedKeys sets
        // combined with the per-transition invariants:
        //   1) soft-delete — only `active`, `deletedAt`, `deletedBy` change
        //   2) name/target edit — only `name`, `contributionTarget`, `updatedAt`, `updatedBy` change
        //   3) member edit — only `memberCount`, `memberNames`, `updatedAt`, `updatedBy` change
        //
        // Using `affectedKeys().hasOnly([...])` is the idiomatic Firestore
        // pattern — it lets the rule allow exactly the fields each
        // transition touches and reject anything else.
        allow update: if isAdmin()
          && (
            // 1) soft-delete
            (
              resource.data.active == true
              && request.resource.data.active == false
              && request.resource.data.deletedBy == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'active', 'deletedAt', 'deletedBy'
              ])
            )
            ||
            // 2) name/target edit
            (
              resource.data.active == true
              && request.resource.data.active == true
              && request.resource.data.deletedAt == resource.data.deletedAt
              && request.resource.data.deletedBy == resource.data.deletedBy
              && request.resource.data.contributionTarget is number
              && request.resource.data.contributionTarget >= 0
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'name', 'contributionTarget', 'updatedAt', 'updatedBy'
              ])
            )
            ||
            // 3) member edit
            (
              resource.data.active == true
              && request.resource.data.active == true
              && request.resource.data.deletedAt == resource.data.deletedAt
              && request.resource.data.deletedBy == resource.data.deletedBy
              && request.resource.data.name == resource.data.name
              && request.resource.data.contributionTarget == resource.data.contributionTarget
              && request.resource.data.memberCount is number
              && request.resource.data.memberCount >= 0
              && request.resource.data.memberNames is list
              && request.resource.data.memberNames.size() == request.resource.data.memberCount
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'memberCount', 'memberNames', 'updatedAt', 'updatedBy'
              ])
            )
          );

        allow delete: if isAdmin();

        // ---- payments (sub-sub-collection) ----

        match /payments/{paymentId} {
          allow read: if isAdmin();

          allow create: if isAdmin()
                      && request.resource.data.recordedBy == request.auth.uid
                      && request.resource.data.recordedAt == request.time
                      && request.resource.data.amount is number
                      && request.resource.data.amount > 0
                      && request.resource.data.month is string
                      && request.resource.data.month.matches('^\\d{4}-(0[1-9]|1[0-2])$')
                      // 003 — coverageGroupId, when present, MUST be a UUID.
                      && (
                        !('coverageGroupId' in request.resource.data)
                        || (request.resource.data.coverageGroupId is string
                            && request.resource.data.coverageGroupId.matches(
                                 '^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$'))
                      )
                      && validOptionalAttachment();

          allow update: if false;
          allow delete: if isAdmin();
        }

        // ---- member history (sub-sub-collection, per family) ----
        // Append-only. The atomic create is the same batched write that
        // updates the family doc's member fields.
        match /memberHistory/{historyId} {
          allow read: if isAdmin();

          allow create: if isAdmin()
            && request.resource.data.changedBy == request.auth.uid
            && request.resource.data.changedAt == request.time
            && request.resource.data.householdId == householdId
            && request.resource.data.familyId == familyId
            && request.resource.data.previousCount is number
            && request.resource.data.previousCount >= 0
            && request.resource.data.previousNames is list
            && request.resource.data.newCount is number
            && request.resource.data.newCount >= 0
            && request.resource.data.newNames is list;

          // Append-only: no update. Admin delete allowed for household cascade.
          allow update: if false;
          allow delete: if isAdmin();
        }
      }
    }

    // ---- contributions ----

    match /contributions/{contributionId} {
      allow read: if isAdmin();

      allow create: if isAdmin()
        && request.resource.data.addedBy == request.auth.uid
        && request.resource.data.addedAt == request.time
        && request.resource.data.contributorName is string
        && request.resource.data.contributorName.size() > 0
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.date is timestamp
        && validOptionalAttachment();

      allow update: if false;
      allow delete: if isAdmin();
    }

    // ---- expenses ----

    match /expenses/{expenseId} {
      allow read: if isAdmin();

      // Extended create guard for the type/linkage XOR.
      allow create: if isAdmin()
        && request.resource.data.addedBy == request.auth.uid
        && request.resource.data.addedAt == request.time
        && request.resource.data.withdrawn == false
        && request.resource.data.withdrawnAt == null
        && request.resource.data.withdrawnBy == null
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.month is string
        && request.resource.data.month.matches('^\\d{4}-(0[1-9]|1[0-2])$')
        && (request.resource.data.isRecurring == false || request.resource.data.recurringId is string)
        && (
          // household branch
          (request.resource.data.type == 'household'
            && request.resource.data.householdId is string
            && request.resource.data.mosqueSubCategory == null)
          ||
          // mosque branch
          (request.resource.data.type == 'mosque'
            && request.resource.data.householdId == null
            && request.resource.data.familyId == null
            && (request.resource.data.mosqueSubCategory == 'maintenance'
              || request.resource.data.mosqueSubCategory == 'salary'
              || request.resource.data.mosqueSubCategory == 'other'))
        )
        && validOptionalAttachment();

      // Update (withdraw) requires the new fields to be unchanged.
      allow update: if isAdmin()
        && resource.data.withdrawn == false
        && request.resource.data.withdrawn == true
        && request.resource.data.withdrawnAt == request.time
        && request.resource.data.withdrawnBy == request.auth.uid
        && request.resource.data.name == resource.data.name
        && request.resource.data.amount == resource.data.amount
        && request.resource.data.date == resource.data.date
        && request.resource.data.month == resource.data.month
        && request.resource.data.note == resource.data.note
        && request.resource.data.isRecurring == resource.data.isRecurring
        && request.resource.data.recurringId == resource.data.recurringId
        && request.resource.data.addedAt == resource.data.addedAt
        && request.resource.data.addedBy == resource.data.addedBy
        && request.resource.data.type == resource.data.type
        && request.resource.data.householdId == resource.data.householdId
        && request.resource.data.familyId == resource.data.familyId
        && request.resource.data.mosqueSubCategory == resource.data.mosqueSubCategory
        && (
          request.resource.data.attachmentPath == resource.data.get('attachmentPath', null)
          && request.resource.data.attachmentFileName == resource.data.get('attachmentFileName', null)
          && request.resource.data.attachmentMimeType == resource.data.get('attachmentMimeType', null)
          || (
            resource.data.get('attachmentPath', null) == null
            && validOptionalAttachment()
          )
        );

      allow delete: if isAdmin();
    }

    // ---- recurringExpenses ----

    match /recurringExpenses/{templateId} {
      allow read: if isAdmin();

      // Create accepts the new type/linkage fields and the default-mosque branch.
      allow create: if isAdmin()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.active == true
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && (
          (request.resource.data.type == 'household'
            && request.resource.data.householdId is string
            && request.resource.data.mosqueSubCategory == null)
          ||
          (request.resource.data.type == 'mosque'
            && request.resource.data.householdId == null
            && request.resource.data.familyId == null
            && (request.resource.data.mosqueSubCategory == 'maintenance'
              || request.resource.data.mosqueSubCategory == 'salary'
              || request.resource.data.mosqueSubCategory == 'other'))
        );

      // Update keeps createdAt/createdBy immutable and the new fields well-formed.
      allow update: if isAdmin()
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.type in ['household', 'mosque']
        && (
          request.resource.data.type == 'mosque'
          || (request.resource.data.type == 'household'
            && request.resource.data.householdId is string)
        );

      allow delete: if isAdmin();
    }

    // Default: deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
